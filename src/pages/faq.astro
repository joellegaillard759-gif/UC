      {
        q: 'Urben Construction intervient-il hors du district de Morges ?',
        a: `Oui. Notre zone principale d'intervention couvre le district de Morges, Rolle, Aubonne et Cossonay. Pour des projets spécifiques ou de grande envergure, nous pouvons intervenir sur un périmètre élargi dans le canton de Vaud. N'hésitez pas à nous contacter pour vérifier la faisabilité.`,
        link: { label: 'Nous contacter', href: '/contact' },
      },
    ],
  },
];
---

<Layout
  title="FAQ — Rénovation, maçonnerie et coordination de chantier | Urben Construction"
  description="Faut-il un architecte pour rénover dans le canton de Vaud ? Combien coûte un ravalement de façade ? Locataire ou propriétaire pour les canalisations ? On répond."
>
  <Navbar />

  <!-- HEADER -->
  <section class="bg-gray-900 text-white pt-48 pb-20">
    <div class="max-w-[1440px] mx-auto px-6">
      <p class="text-xs font-semibold tracking-widest uppercase text-[#FF7500] mb-4">Questions fréquentes</p>
      <h1 class="text-4xl md:text-6xl font-black leading-tight max-w-3xl">
        Ce que vous voulez<br />savoir avant de vous lancer.
      </h1>
      <p class="text-gray-400 mt-6 text-lg max-w-xl">
        Rénovation, maçonnerie, coordination de chantier dans le district de Morges — les vraies questions, avec des réponses directes.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 bg-white">
    <div class="max-w-[1440px] mx-auto px-6">
      <div class="max-w-3xl">

        <!-- Recherche -->
        <div class="relative mb-12">
          <input
            id="faq-search"
            type="text"
            placeholder="Rechercher — ex. architecte, permis, façade, chape…"
            class="w-full border border-gray-200 px-5 py-4 pr-12 text-sm text-gray-700 placeholder-gray-400 focus:outline-none focus:border-gray-400 rounded-sm"
          />
          <span class="absolute right-5 top-1/2 -translate-y-1/2 text-gray-300 text-lg">›</span>
        </div>

        <!-- Catégories accordéon -->
        <div id="faq-list">
          {categories.map((cat, ci) => (
            <details class="faq-category group border-t border-gray-200" open={ci === 0}>
              <summary class="flex items-center justify-between py-5 cursor-pointer list-none select-none">
                <span class="text-xs font-bold tracking-widest uppercase text-gray-900">{cat.title}</span>
                <span class="faq-cat-icon text-[#FF7500] font-bold text-xl leading-none w-5 text-center transition-transform">+</span>
              </summary>
              <div class="pb-4">
                {cat.questions.map(item => (
                  <details class="faq-item group/item border-t border-gray-100" data-q={item.q.toLowerCase()}>
                    <summary class="flex items-center justify-between py-2.5 cursor-pointer list-none select-none gap-4">
                      <span class="faq-item-q text-sm text-gray-700 group-open/item:font-semibold group-open/item:text-gray-900 transition-colors leading-snug">{item.q}</span>
                      <span class="faq-item-icon text-gray-300 text-xs flex-shrink-0 transition-transform">▶</span>
                    </summary>
                    <div class="pb-6 pl-0 pr-4">
                      {item.a.split('\n\n').map(para => (
                        <p class="text-gray-600 text-sm leading-relaxed mb-3">{para}</p>
                      ))}
                      <div class="flex flex-wrap gap-6 mt-3">
                        {item.link && (
                          <a href={item.link.href} class="inline-flex items-center gap-2 text-xs font-bold tracking-wide uppercase text-[#FF7500] hover:gap-3 transition-all">
                            <span>{item.link.label}</span>
                            <span>→</span>
                          </a>
                        )}
                        {item.partner && (
                          <a href={item.partner.href} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-xs font-medium text-gray-400 hover:text-gray-600 transition-colors">
                            <span>{item.partner.label}</span>
                            <span>↗</span>
                          </a>
                        )}
                      </div>
                    </div>
                  </details>
                ))}
              </div>
            </details>
          ))}
          <div class="border-t border-gray-200"></div>
        </div>

        <p id="faq-empty" class="hidden text-sm text-gray-400 py-8">Aucun résultat. <a href="/contact" class="text-[#FF7500] font-semibold">Posez-nous votre question directement →</a></p>
      </div>
    </div>
  </section>

  <script>
    // Icônes accordéon catégorie
    document.querySelectorAll('.faq-category').forEach(cat => {
      cat.addEventListener('toggle', () => {
        const icon = cat.querySelector('.faq-cat-icon');
        if (icon) icon.textContent = (cat as HTMLDetailsElement).open ? '−' : '+';
      });
    });

    // Icônes accordéon question
    document.querySelectorAll('.faq-item').forEach(item => {
      item.addEventListener('toggle', () => {
        const icon = item.querySelector('.faq-item-icon');
        if (icon) icon.textContent = (item as HTMLDetailsElement).open ? '▼' : '▶';
      });
    });

    // Recherche
    const searchInput = document.getElementById('faq-search') as HTMLInputElement;
    const faqEmpty = document.getElementById('faq-empty');

    searchInput?.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      let visibleCount = 0;

      document.querySelectorAll('.faq-category').forEach(cat => {
        let catVisible = 0;
        cat.querySelectorAll('.faq-item').forEach(item => {
          const q = (item as HTMLElement).dataset.q || '';
          const match = !query || q.includes(query);
          (item as HTMLElement).style.display = match ? '' : 'none';
          if (match) catVisible++;
        });
        (cat as HTMLElement).style.display = catVisible > 0 ? '' : 'none';
        if (catVisible > 0) {
          visibleCount++;
          if (query) (cat as HTMLDetailsElement).open = true;
        }
      });

      if (faqEmpty) faqEmpty.classList.toggle('hidden', visibleCount > 0);
    });
  </script>

  <!-- CTA -->
  <section class="py-20 bg-gray-900 text-white">
    <div class="max-w-[1440px] mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Votre question n'est pas là ?</h2>
      <p class="text-gray-400 mb-10">On répond à toutes les questions en moins de 24h. Sans engagement.</p>
      <a href="/contact" class="btn-orange btn-orange-on-dark inline-block px-12 py-4 text-sm font-bold tracking-widest uppercase rounded-sm">
        <span>Posez-nous votre question</span>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
