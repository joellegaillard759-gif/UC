---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const prestations = [
  { titre: 'Chape traditionnelle (liée)', desc: 'Chape en mortier de ciment coulée sur le support existant — solution classique pour les rénovations sans désolidarisation.' },
  { titre: 'Chape flottante', desc: 'Chape posée sur une couche isolante phonique ou thermique — obligatoire dans les constructions neuves et recommandée en rénovation.' },
  { titre: 'Plancher chauffant', desc: 'Intégration d\'un réseau de tuyaux dans la chape pour un chauffage par le sol — confort optimal et économies d\'énergie.' },
  { titre: 'Dalle béton', desc: 'Fondation et dalle portante pour garage, sous-sol, terrasse ou extension — armature, coulage et finition compris.' },
  { titre: 'Ragréage et reprise de sol', desc: 'Remise à niveau d\'un sol existant fissuré ou inégal avant pose du revêtement final (carrelage, parquet, résine).' },
  { titre: 'Démolition et évacuation', desc: 'Dépose de l\'ancienne chape ou dalle, évacuation des gravats et préparation du support pour la nouvelle installation.' },
];

const faq = [
  {
    q: 'Quelle différence entre une chape et une dalle ?',
    a: 'La dalle béton est un élément structurel porteur — elle supporte les charges du bâtiment (murs, planchers, mobilier). La chape est une couche de finition coulée sur la dalle pour créer une surface plane, prête à recevoir le revêtement de sol. En rénovation, on travaille souvent sur la chape existante sans toucher à la dalle. En construction neuve ou lors d\'un agrandissement, on réalise les deux.',
  },
  {
    q: 'Combien coûte une chape dans le district de Morges ?',
    a: 'Le coût d\'une chape dépend de la surface, de l\'épaisseur, du type (liée, flottante, avec plancher chauffant) et des travaux de démolition préalables. À titre indicatif, une chape traditionnelle se situe entre CHF 30 et CHF 60 par m². Une chape avec plancher chauffant intégré coûte généralement entre CHF 80 et CHF 130 par m², matériaux et pose compris. Pour une pièce de 50 m², comptez entre CHF 1\'500 et CHF 6\'500 selon les cas.',
  },
  {
    q: 'Peut-on poser un plancher chauffant dans une rénovation ?',
    a: 'Oui, c\'est tout à fait réalisable en rénovation, à condition d\'avoir une hauteur sous plafond suffisante pour absorber l\'épaisseur supplémentaire de la chape (généralement 8 à 12 cm). Le plancher chauffant s\'adapte aussi bien à une chaudière à gaz existante qu\'à une pompe à chaleur, et peut être zonée pièce par pièce. Nous évaluons la faisabilité lors d\'une visite gratuite.',
  },
  {
    q: 'Combien de temps doit sécher une chape avant de poser le carrelage ?',
    a: 'Le temps de séchage d\'une chape ciment est d\'environ 1 semaine par centimètre d\'épaisseur, dans des conditions normales (température 20°C, ventilation correcte). Une chape de 5 cm nécessite donc au minimum 5 semaines avant pose du carrelage. Ce délai est important : poser trop tôt provoque des remontées d\'humidité qui dégradent les colles et les joints. Nous établissons un planning de chantier en tenant compte de ces contraintes.',
  },
  {
    q: 'Faut-il un permis pour couler une dalle en Vaud ?',
    a: 'Pour une simple reprise de chape intérieure, aucun permis n\'est nécessaire. En revanche, la création d\'une nouvelle dalle (pour un agrandissement, un sous-sol ou une terrasse) peut nécessiter un permis de construire selon la nature du projet. Nous vérifions systématiquement ce point avant de démarrer et vous accompagnons dans les démarches si nécessaire.',
  },
];
---

<Layout
  title="Chapes, dalles et planchers chauffants — District de Morges | Urben Construction"
  description="Chape, dalle béton, plancher chauffant ou ragréage : Urben Construction intervient sur tous vos sols dans le district de Morges. Devis gratuit sous 48h."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Chapes, dalles et planchers chauffants",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Urben Construction",
      "url": "https://urbenconstruction.ch",
      "telephone": "+41218610155",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Grancy",
        "addressRegion": "Vaud",
        "addressCountry": "CH"
      }
    },
    "areaServed": "District de Morges, Vaud, Suisse",
    "description": "Chapes, dalles béton, planchers chauffants et ragréage dans le district de Morges."
  })} />

  <Navbar />

  <!-- HEADER -->
  <section class="relative bg-gray-900 text-white pt-48 pb-20 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/sols.jpg" alt="Chape et dalle béton district de Morges" class="w-full h-full object-cover opacity-25" />
    </div>
    <div class="relative max-w-[1440px] mx-auto px-6">
      <p class="text-xs font-semibold tracking-widest uppercase text-[#FF7500] mb-4">Domaines d'intervention</p>
      <h1 class="text-4xl md:text-6xl font-black leading-tight max-w-3xl">
        Chapes, dalles et<br />planchers chauffants.
      </h1>
      <p class="text-gray-300 mt-6 text-lg max-w-xl">
        De la dalle portante au plancher chauffant en passant par la chape de finition — on intervient sur tous vos sols dans le district de Morges.
      </p>
      <div class="flex flex-wrap gap-4 mt-10">
        <a href="/contact" class="btn-orange btn-orange-on-dark px-8 py-4 text-sm font-bold tracking-widest uppercase rounded-sm">
          <span>Demander un devis gratuit</span>
        </a>
        <a href="tel:+41218610155" class="px-8 py-4 text-sm font-bold tracking-widest uppercase text-white border border-white/40 hover:border-white transition-colors rounded-sm">
          +41 21 861 01 55
        </a>
      </div>
    </div>
  </section>

  <!-- PRESTATIONS -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-6">
      <p class="text-xs font-semibold tracking-widest uppercase text-[#FF7500] mb-4">Ce qu'on fait</p>
      <h2 class="text-3xl font-bold mb-4">De la fondation à la finition.</h2>
      <p class="text-gray-500 mb-14 max-w-xl">Qu'il s'agisse de créer une nouvelle dalle, de reprendre une chape dégradée ou d'intégrer un plancher chauffant, on réalise les travaux avec nos propres équipes.</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {prestations.map(p => (
          <div class="bg-gray-50 rounded-xl p-6 border-t-2 border-[#FF7500]">
            <h3 class="text-base font-bold mb-2">{p.titre}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PHOTO + TEXTE -->
  <section class="py-20 bg-gray-50 border-y border-gray-100">
    <div class="max-w-[1440px] mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/sols.jpg" alt="Pose chape plancher chauffant Morges" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase text-[#FF7500] mb-4">Notre approche</p>
          <h2 class="text-3xl font-bold mb-6">Un sol bien posé, c'est un revêtement qui dure.</h2>
          <p class="text-gray-600 leading-relaxed mb-4">Un carrelage qui se décolle, un parquet qui gondole, des joints qui craquent — ces problèmes viennent presque toujours d'une chape mal réalisée ou posée trop tôt. On respecte les temps de séchage et les épaisseurs recommandées, sans prendre de raccourcis.</p>
          <p class="text-gray-600 leading-relaxed mb-4">On coordonne aussi avec les autres corps de métier si nécessaire — plombier pour le réseau de chauffage, électricien pour les sondes — dans le cadre d'un chantier global.</p>
          <p class="text-gray-600 leading-relaxed mb-8">Zone d'intervention : district de Morges, Rolle, Aubonne, Cossonay et environs.</p>
          <a href="/contact" class="btn-orange inline-block px-8 py-4 text-sm font-bold tracking-widest uppercase rounded-sm">
            <span>Prendre contact</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-6">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold tracking-widest uppercase text-[#FF7500] mb-4">Questions fréquentes</p>
        <h2 class="text-3xl font-bold mb-12">Vos questions sur les chapes et dalles.</h2>
        <div class="space-y-0">
          {faq.map(item => (
            <details class="group border-t border-gray-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer list-none select-none gap-4">
                <span class="text-sm font-semibold text-gray-900 leading-snug">{item.q}</span>
                <span class="text-[#FF7500] font-bold text-xl leading-none w-5 text-center flex-shrink-0 group-open:hidden">+</span>
                <span class="text-[#FF7500] font-bold text-xl leading-none w-5 text-center flex-shrink-0 hidden group-open:block">−</span>
              </summary>
              <p class="pb-6 text-sm text-gray-600 leading-relaxed">{item.a}</p>
            </details>
          ))}
          <div class="border-t border-gray-200"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gray-900 text-white">
    <div class="max-w-[1440px] mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Votre projet de sol,<br />notre prochain chantier.</h2>
      <p class="text-gray-400 mb-10">Visite gratuite · Devis détaillé sous 48h · Sans engagement.</p>
      <a href="/contact" class="btn-orange btn-orange-on-dark inline-block px-12 py-4 text-sm font-bold tracking-widest uppercase rounded-sm">
        <span>Demander une visite gratuite</span>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
