---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const prestations = [
  { titre: 'Dalles et terrasses', desc: 'Création de dalles béton ou en pavés pour terrasse, allée ou zone de stationnement — fondation, drainage et finition compris.' },
  { titre: 'Murets et murs de soutènement', desc: 'Construction de murets en béton, en pierre ou en blocs préfabriqués pour délimiter, soutenir et structurer vos espaces extérieurs.' },
  { titre: 'Escaliers extérieurs', desc: 'Création ou réfection d\'escaliers en béton coulé ou en pierre naturelle — résistants au gel, antidérapants et intégrés à votre aménagement.' },
  { titre: 'Allées et chemins', desc: 'Mise en œuvre d\'allées en béton désactivé, stabilisé ou en pavés autobloquants — stables, drainants et adaptés à votre terrain.' },
  { titre: 'Fondations pour annexes', desc: 'Réalisation de fondations pour abri de jardin, carport, pergola ou extension légère — selon les règles de l\'art et les contraintes du terrain.' },
  { titre: 'Reprises et réparations', desc: 'Réparation de dalles fissurées, reprise de murets dégradés, rejointoiement de pavés — on remet vos extérieurs en état sans tout démolir.' },
];

const faq = [
  {
    q: 'Faut-il un permis pour aménager ses extérieurs dans le canton de Vaud ?',
    a: "La plupart des aménagements extérieurs courants (dalles, terrasses, murets de moins de 1,20 m, allées) ne nécessitent pas de permis de construire dans le canton de Vaud, à condition de ne pas modifier le terrain de façon significative. En revanche, un mur de soutènement important, une modification de la pente naturelle du terrain ou la création d'une surface imperméable dépassant certains seuils peuvent nécessiter une annonce à la commune. Nous vérifions ce point avant le démarrage.",
  },
  {
    q: 'Quelle différence entre une dalle en béton et une terrasse en pavés ?',
    a: "Une dalle béton coulée offre une surface plane, durable et peu entretenue, idéale pour un usage intensif (stationnement, zone de travail). Les pavés autobloquants ou la pierre naturelle donnent un résultat esthétique plus chaud, avec une bonne perméabilité à l'eau — avantageux pour la gestion des eaux pluviales. Les deux solutions sont durables si la fondation est bien réalisée. Le choix dépend de l'usage, du style souhaité et du budget.",
  },
  {
    q: 'Combien coûte une terrasse ou une dalle extérieure dans le district de Morges ?',
    a: "Le coût dépend de la surface, des matériaux choisis et des travaux de terrassement préalables. Une dalle béton se situe généralement entre CHF 80 et CHF 150/m², finition comprise. Une terrasse en pavés ou en pierre naturelle démarre autour de CHF 120/m² et peut dépasser CHF 250/m² selon les matériaux. Un devis précis nécessite une visite pour évaluer l'accès, la pente et l'état du terrain.",
  },
  {
    q: "Comment éviter les fissures dans une dalle extérieure ?",
    a: "Les fissures dans les dalles extérieures viennent presque toujours d'une mauvaise préparation du fond — sous-couche insuffisante, terrain mal compacté, absence de joints de dilatation. On réalise systématiquement un terrassement adapté, une fondation correctement compactée et des joints de dilatation tous les 3 à 4 mètres pour absorber les mouvements thermiques. Le gel/dégel vaudois impose une fondation hors gel (minimum 60 cm de profondeur).",
  },
  {
    q: 'Peut-on aménager un jardin en pente dans le district de Morges ?',
    a: "Oui, c'est même l'une des configurations les plus fréquentes dans notre zone d'intervention. Un terrain en pente nécessite un travail de terrassement et souvent des murs de soutènement pour créer des paliers utilisables. Selon la hauteur à soutenir, on choisit entre murets en béton banché, en blocs préfabriqués ou en pierres — chaque solution ayant ses avantages esthétiques et mécaniques. Nous évaluons la meilleure approche lors d'une visite gratuite.",
  },
];
---

<Layout
  title="Aménagements extérieurs — Dalles, murets, terrasses | Urben Construction"
  description="Dalles béton, terrasses, murets de soutènement, escaliers extérieurs : Urben Construction aménage vos espaces extérieurs dans le district de Morges. Devis gratuit."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Aménagements extérieurs",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Urben Construction",
      "url": "https://urbenconstruction.ch",
      "telephone": "+41218610155",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Grancy",
        "addressRegion": "Vaud",
        "addressCountry": "CH"
      }
    },
    "areaServed": "District de Morges, Vaud, Suisse",
    "description": "Dalles, terrasses, murets, escaliers et allées dans le district de Morges."
  })} />

  <Navbar />

  <!-- HEADER -->
  <section class="relative bg-gray-900 text-white pt-48 pb-20 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/exterieurs.jpg" alt="Aménagements extérieurs district de Morges" class="w-full h-full object-cover opacity-25" />
    </div>
    <div class="relative max-w-[1440px] mx-auto px-6">
      <p class="text-xs font-semibold tracking-widest uppercase text-[#FF7500] mb-4">Domaines d'intervention</p>
      <h1 class="text-4xl md:text-6xl font-black leading-tight max-w-3xl">
        Dalles, murets et<br />aménagements extérieurs.
      </h1>
      <p class="text-gray-300 mt-6 text-lg max-w-xl">
        Terrasse, allée, escalier, mur de soutènement — on façonne vos espaces extérieurs avec les mêmes exigences que pour l'intérieur.
      </p>
      <div class="flex flex-wrap gap-4 mt-10">
        <a href="/contact" class="btn-orange btn-orange-on-dark px-8 py-4 text-sm font-bold tracking-widest uppercase rounded-sm">
          <span>Demander un devis gratuit</span>
        </a>
        <a href="tel:+41218610155" class="px-8 py-4 text-sm font-bold tracking-widest uppercase text-white border border-white/40 hover:border-white transition-colors rounded-sm">
          +41 21 861 01 55
        </a>
      </div>
    </div>
  </section>

  <!-- PRESTATIONS -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-6">
      <p class="text-xs font-semibold tracking-widest uppercase text-[#FF7500] mb-4">Ce qu'on fait</p>
      <h2 class="text-3xl font-bold mb-4">Des extérieurs solides et soignés.</h2>
      <p class="text-gray-500 mb-14 max-w-xl">Dalles, terrasses, murets ou escaliers — on réalise vos aménagements extérieurs dans les règles de l'art, avec une attention particulière aux fondations et au drainage.</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {prestations.map(p => (
          <div class="bg-gray-50 rounded-xl p-6 border-t-2 border-[#FF7500]">
            <h3 class="text-base font-bold mb-2">{p.titre}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PHOTO + TEXTE -->
  <section class="py-20 bg-gray-50 border-y border-gray-100">
    <div class="max-w-[1440px] mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/exterieurs.jpg" alt="Terrasse et aménagement extérieur Morges" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase text-[#FF7500] mb-4">Notre approche</p>
          <h2 class="text-3xl font-bold mb-6">La qualité d'un chantier extérieur se voit dans dix ans.</h2>
          <p class="text-gray-600 leading-relaxed mb-4">Un aménagement extérieur mal réalisé, ça se dégrade vite : fissures, affaissement, problèmes de drainage. On soigne la préparation du terrain autant que la finition, parce que c'est là que tout se joue.</p>
          <p class="text-gray-600 leading-relaxed mb-4">Le gel/dégel du district de Morges impose des fondations adaptées. On dimensionne systématiquement hors gel et on prévoit les joints de dilatation nécessaires.</p>
          <p class="text-gray-600 leading-relaxed mb-8">Zone d'intervention : district de Morges, Rolle, Aubonne, Cossonay et environs.</p>
          <a href="/contact" class="btn-orange inline-block px-8 py-4 text-sm font-bold tracking-widest uppercase rounded-sm">
            <span>Prendre contact</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-white">
    <div class="max-w-[1440px] mx-auto px-6">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold tracking-widest uppercase text-[#FF7500] mb-4">Questions fréquentes</p>
        <h2 class="text-3xl font-bold mb-12">Vos questions sur les aménagements extérieurs.</h2>
        <div class="space-y-0">
          {faq.map(item => (
            <details class="group border-t border-gray-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer list-none select-none gap-4">
                <span class="text-sm font-semibold text-gray-900 leading-snug">{item.q}</span>
                <span class="text-[#FF7500] font-bold text-xl leading-none w-5 text-center flex-shrink-0 group-open:hidden">+</span>
                <span class="text-[#FF7500] font-bold text-xl leading-none w-5 text-center flex-shrink-0 hidden group-open:block">−</span>
              </summary>
              <p class="pb-6 text-sm text-gray-600 leading-relaxed">{item.a}</p>
            </details>
          ))}
          <div class="border-t border-gray-200"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gray-900 text-white">
    <div class="max-w-[1440px] mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Votre projet extérieur,<br />notre prochain chantier.</h2>
      <p class="text-gray-400 mb-10">Visite gratuite · Devis détaillé sous 48h · Sans engagement.</p>
      <a href="/contact" class="btn-orange btn-orange-on-dark inline-block px-12 py-4 text-sm font-bold tracking-widest uppercase rounded-sm">
        <span>Demander une visite gratuite</span>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
