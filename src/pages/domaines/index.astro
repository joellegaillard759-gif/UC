---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const domaines = [
  { title: 'Génie civil', text: 'Fondations, dalles portantes, béton armé, reprises en sous-œuvre.', img: '/images/maison.jpg', alt: 'Génie civil gros œuvre district de Morges', href: '/domaines/genie-civil' },
  { title: 'Façades', text: 'Réparation de fissures, crépissage, ravalement — vos façades retrouvent leur éclat.', img: '/images/facades.jpg', alt: 'Rénovation façade district de Morges', href: '/domaines/facades' },
  { title: 'Cheminées', text: 'Rénovation, chemisage, mise en conformité ECA.', img: '/images/cheminee.jpg', alt: 'Rénovation cheminée canton de Vaud', href: '/domaines/cheminees' },
  { title: 'Aménagements extérieurs', text: 'Dalles, murets, terrasses, escaliers, allées.', img: '/images/exterieurs.jpg', alt: 'Aménagements extérieurs district de Morges', href: '/domaines/amenagements-exterieurs' },
  { title: 'Canalisations', text: 'Diagnostic, débouchage, réfection et assainissement de réseau.', img: '/images/canalisations.jpg', alt: 'Canalisations assainissement district de Morges', href: '/domaines/canalisations' },
  { title: 'Sols & chapes', text: 'Chapes, dalles béton, planchers chauffants, ragréage.', img: '/images/sols.jpg', alt: 'Sols chapes district de Morges', href: '/domaines/sols' },
];
---

<Layout
  title="Nos travaux — Maçonnerie, façades, sols, cheminées | Urben Construction"
  description="Génie civil, façades, cheminées, aménagements extérieurs, canalisations, sols : Urben Construction intervient sur tous vos travaux de maçonnerie dans le district de Morges."
>
  <Navbar />

  <!-- HEADER -->
  <section class="bg-gray-900 text-white pt-48 pb-20">
    <div class="max-w-[1440px] mx-auto px-6">
      <p class="text-xs font-semibold tracking-widest uppercase text-[#FF7500] mb-4">Nos travaux</p>
      <h1 class="text-4xl md:text-6xl font-black leading-tight max-w-3xl">
        Ce sur quoi<br />on intervient.
      </h1>
      <p class="text-gray-400 mt-6 text-lg max-w-xl">
        Maçonnerie, structure, façades, extérieurs, canalisations, sols — on couvre l'ensemble des corps de métier liés à la construction et à la rénovation.
      </p>
    </div>
  </section>

  <!-- GRILLE DOMAINES -->
  <section class="py-24 bg-white">
    <div class="max-w-[1440px] mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8">
        {domaines.map(d => (
          <a href={d.href} class="flex flex-col group">
            <div class="aspect-[4/3] overflow-hidden mb-5">
              <img
                src={d.img}
                alt={d.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <h2 class="text-xl font-bold mb-2 group-hover:text-[#FF7500] transition-colors">{d.title}</h2>
            <p class="text-gray-500 text-sm flex-1 mb-4">{d.text}</p>
            <span class="text-sm font-bold text-[#FF7500]">En savoir plus →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gray-900 text-white">
    <div class="max-w-[1440px] mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Votre projet, notre prochain chantier.</h2>
      <p class="text-gray-400 mb-10">Devis gratuit. Première visite sans engagement.</p>
      <a href="/contact" class="btn-orange btn-orange-on-dark inline-block px-12 py-4 text-sm font-bold tracking-widest uppercase rounded-sm">
        <span>Nous contacter</span>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
